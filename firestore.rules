rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Square catalog cache — read-only to signed-in users; only Cloud Functions write.
    match /square_items/{itemId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /square_categories/{catId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /square_sync_state/{stateId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Media documents — signed-in users can read; owner can update bindings/overrides.
    // Tighten `ownerUid` check to match your existing media schema.
    match /media/{mediaId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null
        && (resource.data.ownerUid == null || resource.data.ownerUid == request.auth.uid);
      allow delete: if request.auth != null
        && resource.data.ownerUid == request.auth.uid;
    }
  }
}